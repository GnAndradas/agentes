# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=./data/ocaas.db

# OpenClaw Gateway (Webhook API)
# Uses /hooks/agent and /hooks/wake endpoints
# OpenClaw uses its own model configuration internally
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_WORKSPACE_PATH=~/.openclaw/workspace
# API token for authentication (Bearer token or x-openclaw-token)
OPENCLAW_API_KEY=your-openclaw-api-token

# Security
API_SECRET_KEY=change-this-in-production-min-32-chars

# CORS (for WebSocket connections)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Telegram Notifications (optional)
# Create a bot via @BotFather and get the token
# Get chat_id by messaging the bot and checking /getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Autonomy Configuration
# Levels: manual | supervised | autonomous
AUTONOMY_LEVEL=supervised
# Timeout in ms before fallback action (default 5 minutes)
AUTONOMY_HUMAN_TIMEOUT=300000
# Fallback: pause | reject | auto_approve
AUTONOMY_FALLBACK=pause
