{
  "name": "ocaas",
  "version": "0.1.0",
  "description": "OpenClaw Agent Administration System",
  "type": "module",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "build:check": "bash scripts/check-build-sync.sh",
    "start": "npm run start -w backend",
    "db:generate": "npm run db:generate -w backend",
    "db:push": "npm run db:push -w backend",
    "lint": "npm run lint -w backend && npm run lint -w frontend",
    "clean": "rm -rf backend/dist frontend/dist backend/data/*.db"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
