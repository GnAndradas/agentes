# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=./data/ocaas.db

# OpenClaw Gateway
# APIs used:
#   - /v1/chat/completions (sync) - AI generation
#   - /hooks/agent (async) - notifications
# Docs: https://docs.openclaw.ai
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_WORKSPACE_PATH=~/.openclaw/workspace
# API token - get from: openclaw config get gateway.token
OPENCLAW_API_KEY=your-openclaw-api-token

# Security
API_SECRET_KEY=change-this-in-production-min-32-chars

# CORS (for WebSocket connections)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Telegram Notifications (optional)
# Create a bot via @BotFather and get the token
# Get chat_id by messaging the bot and checking /getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# SECURITY: Comma-separated list of user IDs allowed to approve/reject
# Get your user ID by messaging @userinfobot on Telegram
# If not set, NO ONE can approve via Telegram (secure by default)
TELEGRAM_ALLOWED_USER_IDS=
# SECURITY: Secret token for webhook validation
# Generate with: openssl rand -hex 32
# Must be set when registering webhook with Telegram via setWebhook API
TELEGRAM_WEBHOOK_SECRET=

# Autonomy Configuration
# Levels: manual | supervised | autonomous
AUTONOMY_LEVEL=supervised
# Timeout in ms before fallback action (default 5 minutes)
AUTONOMY_HUMAN_TIMEOUT=300000
# Fallback: pause | reject | auto_approve
AUTONOMY_FALLBACK=pause

# Task Dispatch Configuration
# DEFAULT_OPENCLAW_AGENT_ID: Agent ID to use when no specific agent is assigned
# Leave empty to auto-select based on capabilities
DEFAULT_OPENCLAW_AGENT_ID=
# TASK_DISPATCH_MODE: How tasks are dispatched to OpenClaw
#   auto: Automatically dispatch tasks to agents based on matching (default)
#   default_agent: Always use DEFAULT_OPENCLAW_AGENT_ID (fallback to first active)
#   manual: Require explicit agent assignment before dispatch
TASK_DISPATCH_MODE=auto

# Intent Router (for OpenClaw integration)
# The /api/intake/router endpoint accepts classified intents from OpenClaw
# See openclaw-config/ directory for OpenClaw agent/tool/skill setup
# No additional env vars needed - uses API_SECRET_KEY for authentication
